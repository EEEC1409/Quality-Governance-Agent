{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["logoUrl", "videoUrl", "version"],
  "properties": {
    "logoUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "videoUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
